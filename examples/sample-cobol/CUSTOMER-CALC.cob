       IDENTIFICATION DIVISION.
       PROGRAM-ID. CUSTOMER-CALC.
       AUTHOR. RENOVATIO-DEMO.
       
       ENVIRONMENT DIVISION.
       CONFIGURATION SECTION.
       SOURCE-COMPUTER. IBM-PC.
       OBJECT-COMPUTER. IBM-PC.
       
       DATA DIVISION.
       WORKING-STORAGE SECTION.
       01  WS-CUSTOMER-RECORD.
           05  WS-CUSTOMER-ID      PIC 9(8).
           05  WS-CUSTOMER-NAME    PIC X(30).
           05  WS-CUSTOMER-BALANCE PIC 9(8)V99.
           05  WS-CUSTOMER-STATUS  PIC X(1).
               88  ACTIVE-CUSTOMER VALUE 'A'.
               88  INACTIVE-CUSTOMER VALUE 'I'.
       
       01  WS-INTEREST-RATE        PIC 9V999 VALUE .025.
       01  WS-CALCULATED-INTEREST  PIC 9(8)V99.
       01  WS-NEW-BALANCE         PIC 9(8)V99.
       
       PROCEDURE DIVISION.
       MAIN-PROCESS.
           PERFORM INITIALIZE-PROGRAM
           PERFORM CALCULATE-INTEREST
           PERFORM UPDATE-BALANCE
           PERFORM DISPLAY-RESULTS
           STOP RUN.
       
       INITIALIZE-PROGRAM.
           MOVE 12345678 TO WS-CUSTOMER-ID
           MOVE "JOHN DOE ENTERPRISES" TO WS-CUSTOMER-NAME
           MOVE 10000.00 TO WS-CUSTOMER-BALANCE
           SET ACTIVE-CUSTOMER TO TRUE.
       
       CALCULATE-INTEREST.
           IF ACTIVE-CUSTOMER
               COMPUTE WS-CALCULATED-INTEREST = 
                   WS-CUSTOMER-BALANCE * WS-INTEREST-RATE
           ELSE
               MOVE ZERO TO WS-CALCULATED-INTEREST
           END-IF.
       
       UPDATE-BALANCE.
           COMPUTE WS-NEW-BALANCE = 
               WS-CUSTOMER-BALANCE + WS-CALCULATED-INTEREST.
       
       DISPLAY-RESULTS.
           DISPLAY "Customer ID: " WS-CUSTOMER-ID
           DISPLAY "Customer Name: " WS-CUSTOMER-NAME
           DISPLAY "Original Balance: " WS-CUSTOMER-BALANCE
           DISPLAY "Interest Rate: " WS-INTEREST-RATE
           DISPLAY "Calculated Interest: " WS-CALCULATED-INTEREST
           DISPLAY "New Balance: " WS-NEW-BALANCE.